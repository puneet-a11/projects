#include<iostream>
using namespace std;

// ================= ACCOUNT =================
class Account {
protected:
    string name, address, city, state, nominee;
    int acc_no, pin, pincode;
    long long mobile;
    float balance;

public:
    virtual void take_input() = 0;
    virtual void special() = 0;

    virtual bool withdraw(float amt) {
        if(amt <= 0) {
            cout << "Invalid amount\n";
            return false;
        }

        if(amt > balance) {
            cout << "Insufficient balance\n";
            return false;
        }

        balance -= amt;
        cout << "Withdraw successful\n";
        return true;
    }

    void deposit(float amt) {
        if(amt <= 0) {
            cout << "Invalid amount\n";
            return;
        }
        balance += amt;
        cout << "Deposit successful\n";
    }

    int getAcc() { return acc_no; }
    int getPin() { return pin; }
    float getBal() { return balance; }

    // setters
    void setAcc(int n) { acc_no = n; }
    void setName(string n) { name = n; }
    void setPin(int p) { pin = p; }
    void setMobile(long long m) { mobile = m; }
    void setAddress(string a) { address = a; }
    void setCity(string c) { city = c; }
    void setState(string s) { state = s; }
    void setPincode(int p) { pincode = p; }
    void setNominee(string n) { nominee = n; }
    void setBalance(float b) { balance = b; }

    void show() {
        cout << "\n====== ACCOUNT DETAILS ======\n";
        cout << "Name      : " << name;
        cout << "\nAcc No    : " << acc_no;
        cout << "\nBalance   : " << balance;
        cout << "\nMobile    : " << mobile;
        cout << "\nAddress   : " << address;
        cout << "\nCity      : " << city;
        cout << "\nState     : " << state;
        cout << "\nPincode   : " << pincode;
        cout << "\nNominee   : " << nominee << endl;
    }
};

// ================= SAVINGS =================
